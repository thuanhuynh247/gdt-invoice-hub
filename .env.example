# ============================================================
# GDT Invoice Hub v17.0.0 — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to Git!
# ============================================================

# ── Flask Core ───────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-secret-key-to-something-strong-32chars
FLASK_DEBUG=false
# Set to false for production!

# ── GDT Portal Connection ────────────────────────────────────
GDT_BASE_URL=https://hoadondientu.gdt.gov.vn
GDT_USE_MOCK=true
# Set to false when connecting to the real GDT portal
GDT_TIMEOUT_SECONDS=30
GDT_USERNAME=
# Your MST (e.g., 0109998887)
GDT_PASSWORD=
# Your GDT portal password

# ── AI / Ollama (Optional) ───────────────────────────────────
OLLAMA_API_URL=http://localhost:11434
# Local Ollama server for RAG chatbot and AI auditor

# ── Telegram Alerts (Optional) ───────────────────────────────
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=-1001234567890

# ── SMTP Email Alerts (Optional) ─────────────────────────────
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ── Encryption Key (for credential storage) ──────────────────
ENCRYPTION_KEY=change-this-encryption-key-32chars
JWT_SECRET=change-this-jwt-secret-key
